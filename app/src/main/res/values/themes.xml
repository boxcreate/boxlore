<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Simple launch theme -->
    <!-- Base application theme -->
    <style name="Theme.BoxLore" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Edge-to-edge is handled by enableEdgeToEdge() in MainActivity -->
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.BoxLore.Splash" parent="Theme.SplashScreen">
        <!-- Define primary color for the adaptive logo -->
        <item name="colorPrimary">@color/splash_logo_color</item> 
        <item name="windowSplashScreenBackground">?attr/colorSurface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.BoxLore</item>
    </style>
</resources>
